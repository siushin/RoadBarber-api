# 服务端口
PORT=8080

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=roadbarber

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置（生产环境必须修改密钥）
JWT_SECRET=your-secret-key-change-in-production
# JWT 过期秒数，默认 86400（24h）
JWT_EXPIRES_IN=86400

# 阿里云短信配置（四项都填写时启用 AliyunProvider，否则降级 ConsoleProvider）
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_SIGN_NAME=
# ALIYUN_TEMPLATE_CODE=